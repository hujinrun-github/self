{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PortfolioBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::portfolio-media"
      ]
    },
    {
      "Sid": "PortfolioObjectReadWriteDelete",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::portfolio-media/*"
      ]
    }
  ]
}
