#!/usr/bin/env bash

set -euo pipefail

if [[ -n "${TRACE_FILE:-}" ]]; then
  printf 'git %s\n' "$*" >>"$TRACE_FILE"
fi

if [[ "${1:-}" == "rev-parse" && "${2:-}" == "--verify" && "${3:-}" == "HEAD" ]]; then
  if [[ -n "${MOCK_GIT_HEAD:-}" ]]; then
    printf '%s\n' "$MOCK_GIT_HEAD"
    exit 0
  fi
  exit 1
fi

if [[ "${1:-}" == "diff" ]]; then
  printf '%s\n' "${MOCK_GIT_DIFF:-}"
  exit 0
fi

exit 0
