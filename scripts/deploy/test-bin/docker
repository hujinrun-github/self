#!/usr/bin/env bash

set -euo pipefail

if [[ -n "${TRACE_FILE:-}" ]]; then
  printf 'docker %s\n' "$*" >>"$TRACE_FILE"
fi

if [[ "${1:-}" == "compose" && "${2:-}" == "up" && "${3:-}" == "--help" ]]; then
  printf '%s\n' "${MOCK_DOCKER_HELP:-Usage: docker compose up --wait}"
  exit 0
fi

if [[ "${1:-}" == "ps" ]]; then
  printf '%s\n' "${MOCK_DOCKER_PS:-}"
  exit 0
fi

exit 0
